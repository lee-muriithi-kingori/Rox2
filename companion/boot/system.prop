# Rox-Boot system properties
# Only contains the actual universal Google values I will defend.
# Everything else stays at whatever the (patched) boot image had —
# we do not invent numbers we cannot verify.

# Boot state (the same shape Rox2 sets, kept here for users running
# Rox-Boot without Rox2).
ro.boot.flash.locked=1
ro.boot.verifiedbootstate=green
ro.boot.veritymode=enforcing

ro.boot.vbmeta.device_state=locked
ro.boot.vbmeta.avb_version=1.2
ro.boot.vbmeta.hash_alg=sha256

vendor.boot.flash.locked=1
vendor.boot.verifiedbootstate=green
vendor.boot.vbmeta.device_state=locked
vendor.boot.vbmeta.avb_version=1.2
vendor.boot.vbmeta.hash_alg=sha256

ro.secureboot.lockstate=locked
ro.secureboot.devicelock=1
ro.boot.secureboot=1
sys.oem_unlock_allowed=0

ro.boot.mode=boot
ro.bootmode=boot
vendor.boot.mode=boot

ro.build.tags=release-keys
ro.build.type=user
ro.secure=1
ro.adb.secure=1
ro.debuggable=0
ro.force.debuggable=0
ro.boot.selinux=enforcing

ro.crypto.state=encrypted
ro.crypto.type=file

persist.sys.adb.notify=0
